PORT=3002
HOST=0.0.0.0

DATABASE_MIGRATOR_URI=postgres://postgres:@db.vluna.internal:5432/vluna
DATABASE_URI=
VLUNA_PLANE=vluna
VLUNA_DB_SCHEMA=control_plane
# OIDC client/issuer/webhook settings now live in realms.metadata (see docs/billing/seed_minimal.sql)

BILLING_MASTER_KEY=realm-default
BOOTSTRAP_REALM_ID=realm-default
BILLING_OWNER_ROLE=

VLUNA_GATE_ENABLE_AUTO_REGISTRY=true
VLUNA_GATE_ENABLE_LEDGER_SYNC=false
VLUNA_GRANT_SWEEP_MAX_PERIODS=120
VLUNA_GRANT_SWEEP_BINDINGS_LIMIT=0
VLUNA_GRANT_SWEEP_INTERVAL_MS=30000
VLUNA_SETTLEMENT_SWEEP_INTERVAL_MS=30000
VLUNA_GRANT_EXPIRY_SWEEP_INTERVAL_MS=30000
VLUNA_SETTLEMENT_BUDGET_IDLE_MS=60000

SEED_REALM_METADATA_JSON='{
  "payments": {
    "stripe": {
      "mode": "test",
      "api_keys": {
        "test": "<YOUR_KEY>"
      },
      "webhooks": [
        {
          "name": "payment",
          "test": "<YOUR_KEY>"
        }
      ],
      "public_webhook_base_url": "https://bg.gate.tapray.com"
    }
  }
}'
